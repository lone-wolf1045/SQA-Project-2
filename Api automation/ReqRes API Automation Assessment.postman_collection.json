				{
					"name": "PATCH Single Field and Verify",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200\", function () {\r",
									"    pm.response.to.have.status(200);\r",
									"});\r",
									"\r",
									"const response = pm.response.json();\r",
									"\r",
									"pm.test(\"Patched job is correct\", function () {\r",
									"    pm.expect(response.job).to.eql(pm.environment.get(\"patchedJob\"));\r",
									"});\r",
									"\r",
									"pm.test(\"updatedAt timestamp is present\", function () {\r",
									"    pm.expect(response).to.have.property(\"updatedAt\");\r",
									"    pm.expect(response.updatedAt).to.not.be.empty;\r",
									"});\r",
									"\r",
									"pm.test(\"updatedAt is a valid date\", function () {\r",
									"    const updatedAt = new Date(response.updatedAt);\r",
									"    pm.expect(updatedAt.toString()).to.not.eql(\"Invalid Date\");\r",
									"});\r",
									"\r",
									"pm.test(\"Name field is not changed in PATCH response\", function () {\r",
									"    pm.expect(response).to.not.have.property(\"name\");\r",
									"});\r",
									"\r",
									"pm.environment.set(\"patchUpdatedAt\", response.updatedAt);"
								],
								"type": "text/javascript",
								"packages": {},
								"requests": {}
							}
						}
