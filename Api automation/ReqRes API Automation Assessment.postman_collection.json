		{
			"name": "User API",
			"item": [
				{
					"name": "Get User and Verify Name Email",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200\", function () {\r",
									"    pm.response.to.have.status(200);\r",
									"});\r",
									"\r",
									"const response = pm.response.json();\r",
									"const user = response.data;\r",
									"\r",
									"pm.test(\"User ID matches\", function () {\r",
									"    pm.expect(user.id).to.eql(Number(pm.environment.get(\"userId\")));\r",
									"});\r",
									"\r",
									"pm.test(\"First name matches\", function () {\r",
									"    pm.expect(user.first_name).to.eql(pm.environment.get(\"expectedFirstName\"));\r",
									"});\r",
									"\r",
									"pm.test(\"Last name matches\", function () {\r",
									"    pm.expect(user.last_name).to.eql(pm.environment.get(\"expectedLastName\"));\r",
									"});\r",
									"\r",
									"pm.test(\"Email matches\", function () {\r",
									"    pm.expect(user.email).to.eql(pm.environment.get(\"expectedEmail\"));\r",
									"});\r",
									"\r",
									"pm.environment.set(\"originalFirstName\", user.first_name);\r",
									"pm.environment.set(\"originalLastName\", user.last_name);\r",
									"pm.environment.set(\"originalEmail\", user.email);"
								],
								"type": "text/javascript",
								"packages": {},
								"requests": {}
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "x-api-key",
								"value": "{{apiKey}}",
								"type": "text"
							},
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{authToken}}",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/users/{{userId}}",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"users",
								"{{userId}}"
							]
						}
					},
					"response": []
				},
				{
					"name": "PUT Update Profile and Verify updatedAt",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200\", function () {\r",
									"    pm.response.to.have.status(200);\r",
									"});\r",
									"\r",
									"const response = pm.response.json();\r",
									"\r",
									"pm.test(\"Updated name is correct\", function () {\r",
									"    pm.expect(response.name).to.eql(pm.environment.get(\"updatedName\"));\r",
									"});\r",
									"\r",
									"pm.test(\"Updated job is correct\", function () {\r",
									"    pm.expect(response.job).to.eql(pm.environment.get(\"updatedJob\"));\r",
									"});\r",
									"\r",
									"pm.test(\"updatedAt timestamp is present\", function () {\r",
									"    pm.expect(response).to.have.property(\"updatedAt\");\r",
									"    pm.expect(response.updatedAt).to.not.be.empty;\r",
									"});\r",
									"\r",
									"pm.test(\"updatedAt is a valid date\", function () {\r",
									"    const updatedAt = new Date(response.updatedAt);\r",
									"    pm.expect(updatedAt.toString()).to.not.eql(\"Invalid Date\");\r",
									"});\r",
									"\r",
									"pm.environment.set(\"putUpdatedAt\", response.updatedAt);"
								],
								"type": "text/javascript",
								"packages": {},
								"requests": {}
							}
						}
					],
					"request": {
						"method": "PUT",
						"header": [
							{
								"key": "x-api-key",
